{
  "name": "threely",
  "version": "1.0.0",
  "description": "A Three.js DSL library for functional 3D graphics programming",
  "keywords": [
    "threejs",
    "3d",
    "graphics",
    "dsl",
    "functional",
    "webgl"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/threely.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/three": "^0.177.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lsp-client": "^6.1.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.37.1",
    "@lezer/javascript": "^1.5.1",
    "@preact/signals": "^2.3.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@solidjs/signals": "^0.3.2",
    "@vtsls/language-service": "^0.2.9",
    "codemirror": "^6.0.1",
    "three": "^0.177.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.0.1",
    "uuid": "^11.1.0",
    "vscode-languageserver": "^9.0.1",
    "ws": "^8.18.3"
  },
  "scripts": {
    "build:package": "npm run build:types && npm run build:bundle",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist src/lib.ts",
    "build:bundle": "node build-lib.mjs",
    "build": "node esbuild.mjs",
    "test": "jest",
    "prepublishOnly": "npm run build"
  }
}
